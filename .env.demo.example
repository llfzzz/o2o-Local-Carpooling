# Demo-profile environment template. Copy to .env, then fill the three crypto secrets
# (or just run scripts/generate-local-env.sh, which writes a complete .env for you).
#
# The middleware credentials below are throwaway, local-only values that MATCH
# docker-compose.yml so the self-contained demo stack works out of the box. They are NOT
# real secrets and must never be used outside the local demo. The crypto secrets are left
# as placeholders on purpose — never commit generated secret material.

SPRING_PROFILES_ACTIVE=demo

# Demo forces all business providers to the interactive mock adapters (see
# carpooling-providers.yml), so these stay blank.
SMS_PROVIDER=
OCR_PROVIDER=
PAYMENT_PROVIDER=
IDENTITY_PROVIDER=
MAP_PROVIDER=
NOTIFICATION_PROVIDER=

NACOS_ADDR=127.0.0.1:8848
NACOS_DISCOVERY_ENABLED=true
SENTINEL_DASHBOARD=127.0.0.1:8858

# Generate unique values — do NOT commit. See scripts/generate-local-env.sh.
JWT_BASE64_SECRET=replace-with-64-byte-base64-hs512-secret
JWT_TOKEN_VALIDITY=PT30M
JWT_REFRESH_VALIDITY=P7D
FIELD_ENCRYPTION_KEY_BASE64=replace-with-32-byte-base64-aes-key
PAYMENT_WEBHOOK_SECRET=replace-with-payment-webhook-hmac-secret

RATE_LIMIT_BACKEND=memory
RATE_LIMIT_AUTH_COUNT=20
RATE_LIMIT_AUTH_PERIOD=PT60S
RATE_LIMIT_API_COUNT=120
RATE_LIMIT_API_PERIOD=PT60S

# Local demo middleware (matches docker-compose.yml). Local-only throwaway values.
MYSQL_JDBC_URL=jdbc:mysql://127.0.0.1:3306/o2o_carpooling?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
MYSQL_USERNAME=o2o_app
MYSQL_PASSWORD=local-app-pass
FLYWAY_ENABLED=true

RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=o2o
RABBITMQ_PASSWORD=local-rabbit-pass

MONGODB_URI=mongodb://o2o:local-mongo-pass@127.0.0.1:27017/o2o_audit?authSource=admin

MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_BUCKET=o2o-carpooling-private
MINIO_ACCESS_KEY=o2o_minio
MINIO_SECRET_KEY=local-minio-pass
MINIO_PRESIGN_UPLOAD_EXPIRY=PT15M
MINIO_PRESIGN_DOWNLOAD_EXPIRY=PT10M

# External business provider credentials stay blank in demo.
AMAP_API_KEY=
AMAP_BASE_URL=https://restapi.amap.com
