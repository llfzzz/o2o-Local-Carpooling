# Copy to .env and fill in real values. NEVER commit a real .env or any real secret.
# For a ready-to-run local demo, generate a .env with fresh random secrets:
#     scripts/generate-local-env.sh
# This template intentionally contains NO usable secrets — only placeholders.

# --- Active profile -------------------------------------------------------------
# demo | staging | production. Demo enables interactive mock providers + Demo Inbox.
SPRING_PROFILES_ACTIVE=demo

# --- Business provider selection (only used by staging/production) ---------------
# In the demo profile these are forced to "demo" by carpooling-providers.yml.
# In staging/production set them to a real adapter name (e.g. aliyun, stripe, amap).
SMS_PROVIDER=
OCR_PROVIDER=
PAYMENT_PROVIDER=
IDENTITY_PROVIDER=
MAP_PROVIDER=amap
NOTIFICATION_PROVIDER=

# --- Service routing ------------------------------------------------------------
# Nacos service discovery was dropped (S32): the gateway and every Feign client resolve
# backends from O2O_<SERVICE>_SERVICE_URL, defaulting to 127.0.0.1:<port>. Leave discovery
# off unless you deliberately reintroduce Nacos. Override a backend address only when a
# service does not run on its default local port, e.g.:
#   O2O_ORDER_SERVICE_URL=http://127.0.0.1:8105
NACOS_DISCOVERY_ENABLED=false
# NACOS_ADDR=127.0.0.1:8848      # only if discovery is re-enabled
# SENTINEL_DASHBOARD=127.0.0.1:8858

# --- Security secrets (REQUIRED; generate unique values, never reuse) ------------
# JWT signing key: 64-byte Base64 for HS512. Generate: openssl rand -base64 64
JWT_BASE64_SECRET=replace-with-64-byte-base64-hs512-secret
JWT_TOKEN_VALIDITY=PT30M
JWT_REFRESH_VALIDITY=P7D
# Field encryption key: 16/24/32-byte Base64 for AES. Generate: openssl rand -base64 32
FIELD_ENCRYPTION_KEY_BASE64=replace-with-32-byte-base64-aes-key
# Payment webhook HMAC secret. Generate: openssl rand -base64 32
PAYMENT_WEBHOOK_SECRET=replace-with-payment-webhook-hmac-secret

# --- Rate limiting --------------------------------------------------------------
# backend=memory keeps per-instance counters (fine for a single gateway). The Redis-backed
# distributed limiter is deferred (the gateway does not depend on spring-data-redis yet).
RATE_LIMIT_BACKEND=memory
RATE_LIMIT_AUTH_COUNT=20
RATE_LIMIT_AUTH_PERIOD=PT60S
RATE_LIMIT_API_COUNT=120
RATE_LIMIT_API_PERIOD=PT60S
# Map endpoints get their own tighter bucket (each call costs external provider quota).
RATE_LIMIT_MAP_COUNT=60
RATE_LIMIT_MAP_PERIOD=PT60S
# Behind a reverse proxy the gateway keys unauthenticated traffic by the real client IP taken from
# X-Real-IP / X-Forwarded-For. Loopback peers (the on-host nginx) are trusted automatically; add any
# NON-loopback proxy/LB addresses so their forwarded IPs are trusted. List form, e.g.:
#   SECURITY_RATE_LIMIT_TRUSTED_PROXIES_0=10.0.0.5

# --- Datasource / middleware ----------------------------------------------------
# Demo middleware credentials are provided by scripts/generate-local-env.sh and must
# match docker-compose.yml. For staging/production these are real, env-injected secrets.
MYSQL_JDBC_URL=jdbc:mysql://127.0.0.1:3306/o2o_carpooling?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
MYSQL_USERNAME=replace-with-db-username
MYSQL_PASSWORD=replace-with-db-password
FLYWAY_ENABLED=true
# HikariCP pool sizing (each JDBC service). Sizing is now declared in each service's application.yml
# (env-overridable) so a bare `java -jar` can't silently fall back to the 10-connection default; these
# override per environment. The low-mem systemd profile intentionally sets a pool of 2.
HIKARI_MAXIMUM_POOL_SIZE=10
HIKARI_MINIMUM_IDLE=2
HIKARI_CONNECTION_TIMEOUT=30000
HIKARI_IDLE_TIMEOUT=600000
HIKARI_MAX_LIFETIME=1800000
# Inter-service Feign read timeout (ms). The systemd unit sets 30000 (was 90000) so a stalled
# downstream frees the caller thread sooner; raise per service if a cold start needs longer.
SPRING_CLOUD_OPENFEIGN_CLIENT_CONFIG_DEFAULT_READ_TIMEOUT=30000

RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=replace-with-rabbitmq-username
RABBITMQ_PASSWORD=replace-with-rabbitmq-password
ORDER_OUTBOX_PUBLISH_BATCH_SIZE=50
ORDER_OUTBOX_PUBLISH_FIXED_DELAY=PT10S
ORDER_OUTBOX_RETRY_DELAY=PT30S
ORDER_TIMEOUT_SCAN_FIXED_DELAY=PT5M
ORDER_PAYMENT_DEADLINE=PT15M
# Seat-lock reconciliation backstop: re-drives the idempotent trip-service seat release for orders
# cancelled within the lookback window, repairing a lock that a failed release left dangling.
ORDERS_SEAT_RECONCILIATION_FIXED_DELAY=PT5M
ORDERS_SEAT_RECONCILIATION_LOOKBACK=PT30M

MONGODB_URI=mongodb://replace-with-mongo-username:replace-with-mongo-password@127.0.0.1:27017/o2o_audit?authSource=admin

MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_BUCKET=o2o-carpooling-private
MINIO_ACCESS_KEY=replace-with-minio-access-key
MINIO_SECRET_KEY=replace-with-minio-secret-key
MINIO_PRESIGN_UPLOAD_EXPIRY=PT15M
MINIO_PRESIGN_DOWNLOAD_EXPIRY=PT10M

# --- External business provider credentials (blank in demo; real in production) --
# AMap server-to-server Web Service key. Server-side only — never sent to the browser.
# Used by map-service for geocoding, reverse geocoding, POI search and route calculation.
AMAP_API_KEY=
AMAP_BASE_URL=https://restapi.amap.com
AMAP_CONNECT_TIMEOUT=PT2S
AMAP_READ_TIMEOUT=PT5S
MAP_ROUTE_CACHE_ENABLED=true
MAP_ROUTE_CACHE_FRESH_TTL=PT30M
MAP_ROUTE_CACHE_STALE_IF_ERROR=PT24H
MAP_PROVIDER_CB_SLIDING_WINDOW_SIZE=20
MAP_PROVIDER_CB_MINIMUM_CALLS=10
MAP_PROVIDER_CB_FAILURE_RATE=50
MAP_PROVIDER_CB_OPEN_DURATION=PT30S
MAP_PROVIDER_CB_HALF_OPEN_CALLS=3

# AMap JS API (browser SDK) — a SEPARATE Web key used only to render tiles, markers and the route
# polyline.
#
# ⚠️ THIS FILE IS NOT WHERE IT GOES. Vite reads env files from apps/user-h5/, not the repo root
#    (vite.config.ts: loadEnv(mode, appRoot)), so a value set here is silently ignored and the
#    map renders "地图未配置". It is listed here only so the full credential set is discoverable.
#
#    Put it in ONE of:
#      apps/user-h5/.env.local          <- local dev
#      VITE_AMAP_JS_KEY=... pnpm build  <- CI / server build
#
# ⚠️ It is baked in at BUILD time, not read at runtime. Changing it requires REBUILDING the H5
#    and redeploying dist/ — pulling and restarting services will not pick it up.
#
# The JSAPI security code is NOT an application environment variable: install it in the root-owned
# nginx secret include documented by deploy/nginx/amap-jscode.conf.example. nginx appends it to
# /_AMapService/ requests, so the browser never receives it.
# VITE_AMAP_JS_KEY=   (see above — set it in apps/user-h5/.env.local, not here)
SMS_ACCESS_KEY=
SMS_SECRET=
SMS_SIGN_NAME=
OCR_API_KEY=
OCR_ENDPOINT=
PAYMENT_API_KEY=
IDENTITY_API_KEY=
IDENTITY_ENDPOINT=
NOTIFY_PUSH_KEY=
